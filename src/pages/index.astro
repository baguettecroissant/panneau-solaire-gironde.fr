---
import BaseLayout from '../layouts/BaseLayout.astro';
import SolarSimulator from '../components/SolarSimulator.astro';
import LeadForm from '../components/LeadForm.astro';
import { guides } from '../data/guides';
import communes from '../data/local-content.json';

const topCities = communes.slice(0, 8);
const bordeaux = communes.find((city) => city.slug === 'bordeaux') || communes[0];
const referenceYield = bordeaux.market.yieldPerKwc;
const referenceThreeKwc = bordeaux.market.threeKwcProduction;
const referenceSixKwc = bordeaux.market.sixKwcProduction;
const referenceNineKwc = bordeaux.market.nineKwcProduction;
const faqs = [
	['Combien coûtent des panneaux solaires en Gironde ?', 'Comptez 7 000 à 9 500 € TTC pour 3 kWc, 12 000 à 16 000 € pour 6 kWc et 16 000 à 22 000 € pour 9 kWc, selon la toiture et les composants.'],
	['Quelle production attendre à Bordeaux ?', `PVGIS 5.3 projette ${referenceYield.toLocaleString('fr-FR')} kWh/kWc/an au centre de Bordeaux, soit environ ${referenceSixKwc.toLocaleString('fr-FR')} kWh/an pour 6 kWc avec 14 % de pertes et des angles optimisés. Une étude de toiture doit ensuite corriger l’orientation et les ombres réelles.`],
	['Le solaire résiste-t-il aux vents atlantiques et à la grêle ?', 'Oui lorsque les modules certifiés et la structure sont dimensionnés selon les charges locales. La fixation dans la charpente et l’assurance décennale sont essentielles.'],
	['Quel installateur choisir dans le 33 ?', 'Choisissez un professionnel QualiPV RGE, assuré pour le photovoltaïque, capable de fournir une étude d’ombre, un schéma électrique et des références matérielles précises.'],
	['Faut-il une batterie pour être rentable ?', 'Pas toujours. Le pilotage du chauffe-eau, de la climatisation, de la piscine ou de la recharge VE améliore d’abord l’autoconsommation. La batterie devient pertinente avec une forte consommation le soir.'],
	['Peut-on revendre le surplus solaire ?', 'Oui, sous conditions, via un contrat d’obligation d’achat. Le tarif et la prime applicables dépendent notamment de la date de demande complète de raccordement.']
];

const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'Organization',
		'@id': 'https://panneau-solaire-gironde.fr/#organization',
		name: 'Panneau Solaire Gironde',
		url: 'https://panneau-solaire-gironde.fr/',
		description: 'Information photovoltaïque, simulation et mise en relation pour des demandes de devis en Gironde.',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'Comparaison de devis photovoltaïques en Gironde',
		provider: { '@id': 'https://panneau-solaire-gironde.fr/#organization' },
		areaServed: { '@type': 'AdministrativeArea', name: 'Gironde' },
		serviceType: 'Mise en relation pour un projet photovoltaïque',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqs.map(([question, answer]) => ({
			'@type': 'Question',
			name: question,
			acceptedAnswer: { '@type': 'Answer', text: answer },
		})),
	},
];
---

<BaseLayout
	title="Panneaux Solaires Gironde (33) — Prix, Rentabilité & Devis 2026"
	description="Panneaux solaires en Gironde : production PVGIS, prix 3 à 9 kWc, aides 2026 et devis gratuits. Vérifiez qualification RGE et assurances."
	schema={schema}
>
	<section class="hero">
		<div class="container hero-inner">
			<div class="hero-copy">
				<div class="hero-badge"><span></span> Données PVGIS · patrimoine + énergie locale</div>
				<h1>Panneaux solaires en Gironde,<br /><em>élégants par nature.</em></h1>
				<p class="hero-lead">
					Panneaux full black, micro-onduleurs et batterie LFP : une étude précise pour transformer votre toiture en énergie locale, sans dénaturer votre maison.
				</p>
				<div class="hero-actions">
					<a class="button button-primary" href="/devis/">Demander mes devis gratuits →</a>
					<a class="button button-hero-secondary" href="#simulateur">Lancer le simulateur</a>
				</div>
				<div class="hero-trust">
					<span><i>✓</i> Qualification RGE à contrôler</span>
					<span><i>✓</i> Devis gratuits</span>
					<span><i>✓</i> Données locales 33</span>
				</div>
			</div>
			<div class="hero-dashboard" aria-label="Exemple de production solaire d’une échoppe bordelaise">
				<div class="dashboard-top">
					<span>Scénario indicatif · échoppe 6 kWc</span>
					<div class="live-badge"><span></span> Production</div>
				</div>
				<div class="dashboard-production">
					<small>Puissance instantanée</small>
					<strong>4,82 <span>kW</span></strong>
				</div>
				<div class="power-chart" aria-hidden="true">
					<span style="height: 17%"></span><span style="height: 27%"></span><span style="height: 42%"></span>
					<span style="height: 58%"></span><span style="height: 75%"></span><span style="height: 92%"></span>
					<span style="height: 100%"></span><span style="height: 91%"></span><span style="height: 74%"></span>
					<span style="height: 54%"></span><span style="height: 34%"></span><span style="height: 19%"></span>
				</div>
				<div class="dashboard-grid">
					<div><small>Aujourd’hui</small><strong>27,4 kWh</strong></div>
					<div><small>Autoconsommé</small><strong>68 %</strong></div>
					<div><small>CO₂ évité</small><strong>11,8 kg</strong></div>
					<div><small>Valeur énergie</small><strong>6,49 €</strong></div>
				</div>
			</div>
		</div>
		<div class="container hero-stats">
			<div class="hero-stat"><strong>{referenceYield.toLocaleString('fr-FR')}</strong><span>kWh/kWc/an · modèle PVGIS Bordeaux</span></div>
			<div class="hero-stat"><strong>8–12 ans</strong><span>retour simple indicatif selon projet</span></div>
			<div class="hero-stat"><strong>25 ans</strong><span>garantie produit disponible</span></div>
			<div class="hero-stat"><strong>140</strong><span>communes analysées dans le 33</span></div>
		</div>
	</section>

	<section class="section" style="padding-top: 150px">
		<div class="container">
			<div class="section-heading center">
				<span class="eyebrow eyebrow-amber">Savoir-faire solaire local</span>
				<h2>La performance, avec le respect du patrimoine.</h2>
				<p>Chaque choix relie une donnée technique à votre cadre de vie : irradiation, ombrage, profil de charge, architecture et durée de vie des composants.</p>
			</div>
			<div class="feature-grid">
				<article class="feature-card">
					<div class="feature-icon">01</div>
					<h3>Étude de production</h3>
					<p>Orientation, pente et masques solaires rapprochés d’un modèle PVGIS fondé sur les coordonnées du projet.</p>
				</article>
				<article class="feature-card">
					<div class="feature-icon">02</div>
					<h3>Intégration soignée</h3>
					<p>Modules sobres, micro-onduleurs ou onduleur hybride selon la toiture, les ombres, les usages et les contraintes patrimoniales.</p>
				</article>
				<article class="feature-card">
					<div class="feature-icon">03</div>
					<h3>Rentabilité lisible</h3>
					<p>Budget net, économies sur 25 ans, prime à l’autoconsommation et valorisation du surplus EDF OA.</p>
				</article>
			</div>
		</div>
	</section>

	<section id="simulateur" class="section section-white">
		<div class="container">
			<SolarSimulator city="Bordeaux" yieldPerKwc={referenceYield} />
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-heading">
				<span class="eyebrow">Puissance & budget</span>
				<h2>Du 3 kWc rationnel au 9 kWc haute performance.</h2>
				<p>Des fourchettes réalistes, installation complète et démarches incluses. Le prix final dépend de la toiture, de l’onduleur et du niveau de pilotage.</p>
			</div>
			<div class="price-grid">
				<article class="price-card">
					<span class="price-power">8 modules · 3 kWc</span>
					<h3>Maison économe</h3>
					<strong class="price-amount">7 000 – 9 500 €</strong>
					<div class="price-meta">Projection PVGIS Bordeaux · {referenceThreeKwc.toLocaleString('fr-FR')} kWh/an</div>
					<p>Idéal pour réduire le talon de consommation et valoriser une toiture de 16 à 20 m².</p>
					<ul class="check-list">
						<li>Autoconsommation + surplus</li><li>Monitoring connecté</li><li>Pose en une journée</li>
					</ul>
				</article>
				<article class="price-card featured">
					<div class="price-ribbon">Le plus choisi</div>
					<span class="price-power">16 modules · 6 kWc</span>
					<h3>Villa équipée</h3>
					<strong class="price-amount">12 000 – 16 000 €</strong>
					<div class="price-meta">Projection PVGIS Bordeaux · {referenceSixKwc.toLocaleString('fr-FR')} kWh/an</div>
					<p>Le point d’équilibre pour une famille avec climatisation, piscine ou véhicule électrique.</p>
					<ul class="check-list">
						<li>Couverture à simuler selon les usages</li><li>Compatible batterie LFP</li><li>Retour calculé scénario par scénario</li>
					</ul>
				</article>
				<article class="price-card">
					<span class="price-power">24 modules · 9 kWc</span>
					<h3>Forte consommation</h3>
					<strong class="price-amount">16 000 – 22 000 €</strong>
					<div class="price-meta">Projection PVGIS Bordeaux · {referenceNineKwc.toLocaleString('fr-FR')} kWh/an</div>
					<p>Pour grande villa, double recharge VE, pompe à chaleur, climatisation et piscine.</p>
					<ul class="check-list">
						<li>Onduleur triphasé possible</li><li>Injection du surplus optimisée</li><li>Pilotage multi-usages</li>
					</ul>
				</article>
			</div>
			<p style="margin-top: 30px"><a class="text-link" href="/tarifs/">Comparer tous les équipements et options →</a></p>
		</div>
	</section>

	<section class="section section-forest">
		<div class="container performance-shell">
			<div class="performance-copy">
				<span class="eyebrow eyebrow-amber">Exemple modélisé · Bordeaux</span>
				<h2>Une courbe de production pensée pour vos usages.</h2>
				<p>À Bordeaux, près de 70 % de la production annuelle arrive entre mars et septembre. Piscine, chauffe-eau et recharge VE deviennent des usages flexibles pilotés par le soleil.</p>
				<div class="metric-row">
					<div class="metric-box"><strong>{referenceSixKwc.toLocaleString('fr-FR')} kWh</strong><span>projection PVGIS · 6 kWc</span></div>
					<div class="metric-box"><strong>68 %</strong><span>autoconsommation pilotée</span></div>
					<div class="metric-box"><strong>1 390 €</strong><span>gain annuel estimatif</span></div>
					<div class="metric-box"><strong>9,1 %</strong><span>TRI indicatif sur 25 ans</span></div>
				</div>
			</div>
			<div class="monthly-dashboard">
				<div class="monthly-dashboard-header">
					<div><small>Production annuelle modélisée</small><br /><strong>6 kWc · Bordeaux</strong></div>
					<div class="live-badge"><span></span> 2026</div>
				</div>
				<div class="month-bars" aria-label="Production mensuelle estimée">
					<div class="month"><i style="height: 36%"></i><span>JAN</span></div>
					<div class="month"><i style="height: 48%"></i><span>FÉV</span></div>
					<div class="month"><i style="height: 72%"></i><span>MAR</span></div>
					<div class="month"><i style="height: 83%"></i><span>AVR</span></div>
					<div class="month"><i style="height: 94%"></i><span>MAI</span></div>
					<div class="month"><i style="height: 100%"></i><span>JUN</span></div>
					<div class="month"><i style="height: 98%"></i><span>JUL</span></div>
					<div class="month"><i style="height: 91%"></i><span>AOÛ</span></div>
					<div class="month"><i style="height: 75%"></i><span>SEP</span></div>
					<div class="month"><i style="height: 58%"></i><span>OCT</span></div>
					<div class="month"><i style="height: 39%"></i><span>NOV</span></div>
					<div class="month"><i style="height: 33%"></i><span>DÉC</span></div>
				</div>
				<div class="dashboard-legend"><span><i></i> Production photovoltaïque</span><span><i></i> Plateau solaire optimal</span></div>
			</div>
		</div>
	</section>

	<section class="section section-white">
		<div class="container">
			<div class="section-heading center">
				<span class="eyebrow eyebrow-amber">Mission en quatre phases</span>
				<h2>De votre toiture au compteur Enedis.</h2>
			</div>
			<div class="process-grid">
				<div class="process-step"><div class="step-number">01</div><h3>Qualification</h3><p>Toiture, consommation, objectifs et budget sont cadrés en quelques minutes.</p></div>
				<div class="process-step"><div class="step-number">02</div><h3>Étude</h3><p>Production, puissance, autoconsommation, TRI et scénarios techniques sont calculés.</p></div>
				<div class="process-step"><div class="step-number">03</div><h3>Installation</h3><p>Un installateur QualiPV RGE pose, raccorde et documente votre centrale.</p></div>
				<div class="process-step"><div class="step-number">04</div><h3>Pilotage</h3><p>Le monitoring mesure chaque kWh et optimise vos usages en temps réel.</p></div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<div class="section-heading">
				<span class="eyebrow">Ancrage girondin</span>
				<h2>140 communes, un potentiel solaire cartographié.</h2>
				<p>De Bordeaux à Libourne et du Médoc au bassin d’Arcachon, les pages locales intègrent production, toiture, urbanisme et données propres à chaque commune.</p>
			</div>
			<div class="city-grid">
				{topCities.map((city) => (
					<a class="city-card" href={`/panneau-solaire-${city.slug}/`}>
						<div class="city-card-header"><h3>{city.name}</h3><span class="postal-pill">{city.postalCode}</span></div>
						<p>{city.market.yieldPerKwc} kWh/kWc/an · {city.population.toLocaleString('fr-FR')} habitants</p>
						<div class="city-card-footer"><span>Prix et devis locaux</span><span>→</span></div>
					</a>
				))}
			</div>
			<p style="margin-top: 30px"><a class="text-link" href="/communes/">Explorer toutes les communes du 33 →</a></p>
		</div>
	</section>

	<section class="section section-white">
		<div class="container">
			<div class="section-heading">
				<span class="eyebrow eyebrow-amber">Base de connaissances</span>
				<h2>Les données avant la décision.</h2>
				<p>Prix, aides, batteries, mobilité électrique et sélection RGE : huit dossiers techniques pour construire un projet vérifiable.</p>
			</div>
			<div class="guide-grid">
				{guides.slice(0, 3).map((guide) => (
					<a class="guide-card" href={`${guide.path || `/guides/${guide.slug}`}/`}>
						<div class="guide-image">
							<picture>
								<source srcset={guide.image.replace(/\.png$/, '.webp')} type="image/webp" />
								<img src={guide.image} alt={`Guide ${guide.shortTitle}`} width="1600" height="900" loading="lazy" decoding="async" />
							</picture>
							<span class="guide-tag">{guide.category}</span>
						</div>
						<div class="guide-content"><h3>{guide.shortTitle}</h3><p>{guide.description}</p><div class="guide-meta"><span>{guide.readTime}</span><span>Lire →</span></div></div>
					</a>
				))}
			</div>
			<p style="margin-top: 30px"><a class="text-link" href="/guides/">Voir les huit guides photovoltaïques →</a></p>
		</div>
	</section>

	<section class="section">
		<div class="container">
			<LeadForm compact={true} />
		</div>
	</section>

	<section class="section section-white">
		<div class="container">
			<div class="section-heading center">
				<span class="eyebrow">Questions fréquentes</span>
				<h2>Précisions techniques, réponses claires.</h2>
			</div>
			<div class="faq-list">
				{faqs.map(([question, answer]) => <details><summary>{question}</summary><p>{answer}</p></details>)}
			</div>
		</div>
	</section>
</BaseLayout>
