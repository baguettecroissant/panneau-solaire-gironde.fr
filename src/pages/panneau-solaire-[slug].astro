---
import BaseLayout from '../layouts/BaseLayout.astro';
import SolarSimulator from '../components/SolarSimulator.astro';
import LeadForm from '../components/LeadForm.astro';
import GirondeSolarMap from '../components/GirondeSolarMap.astro';
import HeritageProjectGuide from '../components/HeritageProjectGuide.astro';
import HeritageRoiCalculator from '../components/HeritageRoiCalculator.astro';
import cities from '../data/local-content.json';
import { atPlace, ofPlace } from '../utils/french-place';

export function getStaticPaths() {
	return cities.map((city) => ({ params: { slug: city.slug }, props: { city } }));
}

const { city } = Astro.props;
const cityAt = atPlace(city.name);
const cityOf = ofPlace(city.name);
const pageTitle = `Panneaux solaires ${cityAt} (${city.postalCode}) | Prix & devis`;
const epciName = city.epciName || 'l’intercommunalité locale';
const solarSource = city.solar?.source || 'PVGIS 5.3';
const lossPercent = city.solar?.lossPercent ?? 14;
const densityLabel = city.densityLabel || 'profil communal';
const relatedCities = cities
	.filter((candidate) => candidate.slug !== city.slug)
	.map((candidate) => ({
		...candidate,
		distance: Math.hypot((candidate.latitude || 0) - (city.latitude || 0), (candidate.longitude || 0) - (city.longitude || 0)),
	}))
	.sort((a, b) => a.distance - b.distance)
	.slice(0, 4);
const faqs = [
	...city.faqs,
	[`Quelle production pour 6 kWc ${cityAt} ?`, `La projection ${solarSource} aux coordonnées communales donne environ ${city.market.sixKwcProduction.toLocaleString('fr-FR')} kWh/an pour 6 kWc, avec les hypothèses documentées sur cette page. Une étude de toiture doit ensuite intégrer l’orientation, la pente et les ombres réelles.`],
	[`Quel budget prévoir ${cityAt} ?`, `Le repère départemental présenté ici va de ${city.priceMin.toLocaleString('fr-FR')} à ${city.priceMax.toLocaleString('fr-FR')} € TTC pour des projets résidentiels courants de 3 à 9 kWc. Il ne s’agit pas d’un tarif propre à la commune : seul un devis après visite peut chiffrer la toiture.`],
];
const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: `Installation de panneaux solaires ${cityAt}`,
		description: city.metaDescription,
		url: `https://panneau-solaire-gironde.fr/panneau-solaire-${city.slug}/`,
		areaServed: { '@type': 'City', name: city.name },
		provider: { '@type': 'Organization', '@id': 'https://panneau-solaire-gironde.fr/#organization', name: 'Panneau Solaire Gironde', url: 'https://panneau-solaire-gironde.fr/' },
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqs.map(([q, a]) => ({ '@type': 'Question', name: q, acceptedAnswer: { '@type': 'Answer', text: a } })),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://panneau-solaire-gironde.fr/' },
			{ '@type': 'ListItem', position: 2, name: 'Communes', item: 'https://panneau-solaire-gironde.fr/communes/' },
			{ '@type': 'ListItem', position: 3, name: city.name },
		],
	},
];
---

<BaseLayout
	title={pageTitle}
	description={city.metaDescription}
	schema={schema}
>
	<section class="page-hero">
		<div class="container">
			<nav class="breadcrumbs" aria-label="Fil d’Ariane"><a href="/">Accueil</a><span>›</span><a href="/communes/">Communes</a><span>›</span><span>{city.name}</span></nav>
			<span class="eyebrow eyebrow-amber">Données officielles · INSEE {city.insee} · {solarSource}</span>
			<h1>Panneaux solaires {cityAt} ({city.postalCode})</h1>
			<p>{city.intro} Comparez ensuite des offres détaillées et vérifiez pour chaque entreprise la qualification RGE, l’assurance photovoltaïque et les hypothèses de production.</p>
			<div class="page-hero-actions">
				<a class="button button-primary" href="#etude">Demander mes devis gratuits →</a>
				<a class="button button-hero-secondary" href="#simulateur-local">Simuler la production</a>
			</div>
			<div class="local-data-strip">
				<div><strong>{city.market.yieldPerKwc}</strong><span>kWh / kWc / an</span></div>
				<div><strong>{city.market.sixKwcProduction.toLocaleString('fr-FR')}</strong><span>kWh/an pour 6 kWc</span></div>
				<div><strong>{lossPercent} %</strong><span>pertes du modèle PVGIS</span></div>
				<div><strong>{city.population.toLocaleString('fr-FR')}</strong><span>habitants</span></div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="container content-layout">
			<article class="prose">
				<h2>Potentiel solaire et toitures {cityAt}</h2>
				<p>{city.localIntro}</p>
				<p>La projection aux coordonnées de la commune donne environ {city.market.threeKwcProduction.toLocaleString('fr-FR')} kWh/an pour 3 kWc, {city.market.sixKwcProduction.toLocaleString('fr-FR')} kWh/an pour 6 kWc et {city.market.nineKwcProduction.toLocaleString('fr-FR')} kWh/an pour 9 kWc. Elle suppose l’inclinaison optimale calculée par {solarSource} et {lossPercent} % de pertes système ; ce n’est pas une mesure de votre toiture.</p>
				<div class="data-callout"><strong>Méthode vérifiable</strong>{city.methodology?.solar?.method || city.solar?.method || `Coordonnées communales issues de l’API Géo française ; productible calculé par ${solarSource}.`} La toiture doit encore être contrôlée sur site : structure, couverture, ventilation, câbles et ombres saisonnières.</div>

				<h2>Aides, Enedis et urbanisme {cityAt}</h2>
				<p>{city.localAdvice}</p>
				<p>La déclaration préalable doit être acceptée avant la pose. En secteur protégé, les prescriptions architecturales peuvent influencer l’implantation, la couleur des cadres et la visibilité depuis l’espace public.</p>

				<h2>Territoire, densité et contraintes de parcelle</h2>
				<p>{city.heritage}</p>
				<p>Le choix entre onduleur central, optimiseurs ou micro-onduleurs dépend du nombre de pans, des ombres et de la maintenance attendue. Aucune technologie n’est retenue par défaut : le devis doit expliquer son intérêt pour le bâtiment étudié.</p>

				<h2>Données du marché solaire {cityAt}</h2>
				<table>
					<tbody>
						<tr><th>Indicateur</th><th>Valeur locale</th></tr>
						<tr><td>Production de référence</td><td>{city.market.yieldPerKwc} kWh/kWc/an · {solarSource}</td></tr>
						<tr><td>Intercommunalité</td><td>{epciName}</td></tr>
						<tr><td>Contrat de vente du surplus</td><td>EDF OA · jusqu’à 20 ans</td></tr>
						<tr><td>Qualification à vérifier</td><td>QualiPV RGE + décennale photovoltaïque</td></tr>
						<tr><td>Repère Gironde · 3 à 9 kWc</td><td>{city.priceMin.toLocaleString('fr-FR')} – {city.priceMax.toLocaleString('fr-FR')} € TTC</td></tr>
					</tbody>
				</table>
				<p>Ces ordres de grandeur servent à cadrer le projet. Le devis final doit préciser matériel, puissance, production simulée, pertes, garantie et valeur de l’énergie autoconsommée.</p>
			</article>
			<aside class="sidebar-card">
				<span class="eyebrow">Mission locale</span>
				<h2>Devis solaires {cityAt}</h2>
				<p>Décrivez votre projet pour comparer des offres, puis contrôlez les qualifications et assurances du professionnel proposé.</p>
				<a class="button button-primary" href="#etude">Demander mes devis →</a>
				<a class="text-link" href={`/installateur-solaire-${city.slug}/`}>Comment choisir un installateur {cityAt} →</a>
				<div class="sidebar-metrics">
					<div><span>Code postal</span><strong>{city.postalCode}</strong></div>
					<div><span>Surface communale</span><strong>{city.surfaceKm2} km²</strong></div>
					<div><span>Coordonnées</span><strong>{city.latitude?.toFixed(2)} / {city.longitude?.toFixed(2)}</strong></div>
				</div>
			</aside>
		</div>
	</section>

	<section class="section section-white">
		<div class="container"><GirondeSolarMap city={city} /></div>
	</section>

	<section class="section">
		<div class="container"><HeritageProjectGuide city={city.name} /></div>
	</section>

	<section class="section section-white">
		<div class="container">
			<HeritageRoiCalculator
				city={city.name}
				yieldPerKwc={city.market.yieldPerKwc}
				priceMin={city.priceMin}
				priceMax={city.priceMax}
			/>
		</div>
	</section>

	<section id="simulateur-local" class="section section-white">
		<div class="container"><SolarSimulator city={city.name} yieldPerKwc={city.market.yieldPerKwc} /></div>
	</section>

	<section class="section section-forest">
		<div class="container performance-shell">
			<div class="performance-copy">
				<span class="eyebrow eyebrow-amber">Dashboard local</span>
				<h2>Production mensuelle estimée {cityAt}.</h2>
				<p>Le profil saisonnier combine irradiation locale et pertes système. La programmation des usages maximise la valeur des mois les plus productifs.</p>
				<div class="metric-row">
					<div class="metric-box"><strong>{city.market.sixKwcProduction.toLocaleString('fr-FR')} kWh</strong><span>production 6 kWc</span></div>
					<div class="metric-box"><strong>{lossPercent} %</strong><span>pertes système modélisées</span></div>
					<div class="metric-box"><strong>{densityLabel}</strong><span>profil de densité communale</span></div>
					<div class="metric-box"><strong>25 ans</strong><span>horizon analysé</span></div>
				</div>
			</div>
			<div class="monthly-dashboard">
				<div class="monthly-dashboard-header"><div><small>Répartition mensuelle illustrative</small><br /><strong>{city.name} · 33</strong></div><div class="live-badge"><span></span> Profil indicatif</div></div>
				<div class="month-bars">
					{[33, 42, 67, 81, 94, 100, 98, 91, 74, 55, 36, 28].map((height, i) => (
						<div class="month"><i style={`height:${height}%`}></i><span>{['JAN','FÉV','MAR','AVR','MAI','JUN','JUL','AOÛ','SEP','OCT','NOV','DÉC'][i]}</span></div>
					))}
				</div>
				<div class="dashboard-legend"><span><i></i> Irradiation mensuelle</span><span><i></i> Zone optimale mars–septembre</span></div>
			</div>
		</div>
	</section>

	<section id="etude" class="section">
		<div class="container"><LeadForm city={city.name} compact={true} heading={`Demander mes devis solaires ${cityAt} (33)`} /></div>
	</section>

	<section class="section section-white">
		<div class="container">
			<div class="section-heading center"><span class="eyebrow">FAQ locale</span><h2>Panneaux solaires {cityAt} : vos questions.</h2></div>
			<div class="faq-list">{faqs.map(([q, a]) => <details><summary>{q}</summary><p>{a}</p></details>)}</div>
		</div>
	</section>
	<section class="section-compact">
		<div class="container">
			<div class="section-heading"><span class="eyebrow">Autour {cityOf}</span><h2>Comparer les communes voisines.</h2></div>
			<div class="city-grid">
				{relatedCities.map((related) => (
					<a class="city-card" href={`/panneau-solaire-${related.slug}/`}>
						<div class="city-card-header"><h3>{related.name}</h3><span class="postal-pill">{related.postalCode}</span></div>
						<p>{related.market.yieldPerKwc} kWh/kWc/an</p>
						<div class="city-card-footer"><span>Voir le potentiel local</span><span>→</span></div>
					</a>
				))}
			</div>
		</div>
	</section>
</BaseLayout>
